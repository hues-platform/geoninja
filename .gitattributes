# Normalize all text files to LF in the repository
* text=auto eol=lf

# Explicitly enforce LF for common frontend files
*.ts  text eol=lf
*.tsx text eol=lf
*.js  text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md  text eol=lf
*.cjs text eol=lf
*.mjs text eol=lf
*.html text eol=lf
