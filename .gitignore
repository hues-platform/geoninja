###############################################################################
# Python / Backend (Poetry, Ruff, MyPy)
###############################################################################

# Virtual environments
.venv/
backend/.venv/

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Ruff / MyPy / type checking
.ruff_cache/
.mypy_cache/

# Test / coverage artifacts
.coverage
htmlcov/

# CI-generated reports (we store them as artifacts, not in git)
backend/ruff_report.txt
backend/mypy_report.xml

###############################################################################
# Pre-commit
###############################################################################

.pre-commit-config.yaml~   # editor backups only

